-- Fungsi Power Fling (lebih kuat + sedikit prediksi)
local function powerFling(target)
	local root = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
	local tRoot = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
	if not root or not tRoot then return end
	
	local bv = Instance.new("BodyVelocity")
	bv.Name = "PowerFling"
	bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
	bv.Velocity = (tRoot.Position - root.Position).Unit * 150 + Vector3.new(0, 50, 0)  -- tambah sedikit ke atas
	bv.Parent = root
	
	spawn(function()
		for i = 1, 40 do
			if not tRoot.Parent then break end
			root.CFrame = tRoot.CFrame * CFrame.new(0, 0, -1.5)
			bv.Velocity = (tRoot.Velocity * 1.2) + Vector3.new(0, 80, 0)
			RunService.Heartbeat:Wait()
		end
		if bv then bv:Destroy() end
	end)
	
	notif("Power Fling", "Yeeting " .. target.Name .. " dengan kekuatan tinggi!", 3)
end

-- Touch Fling Logic
local function enableTouchFling()
	if touchConnection then return end
	touchFlingEnabled = true
	TouchButton.Text = "Touch Fling: ON"
	TouchButton.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
	
	touchConnection = lp.Character:WaitForChild("HumanoidRootPart").Touched:Connect(function(hit)
		local char = hit.Parent
		local plr = Players:GetPlayerFromCharacter(char)
		if plr and plr ~= lp then
			local tRoot = char:FindFirstChild("HumanoidRootPart")
			if tRoot then
				local bv = Instance.new("BodyVelocity")
				bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
				bv.Velocity = lp.Character.HumanoidRootPart.Velocity * 2 + Vector3.new(0, 100, 0)
				bv.Parent = tRoot
				game.Debris:AddItem(bv, 0.6)
			end
		end
	end)
end

local function disableTouchFling()
	touchFlingEnabled = false
	TouchButton.Text = "Touch Fling: OFF"
	TouchButton.BackgroundColor3 = Color3.fromRGB(0, 100, 0)
	if touchConnection then
		touchConnection:Disconnect()
		touchConnection = nil
	end
end

